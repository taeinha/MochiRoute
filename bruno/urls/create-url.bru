meta {
  name: Create URL
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/url
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "originalUrl": "https://example.com/very-long-path",
    "customCode": "demo-link"
  }
}

script:post-response {
  if (res.status === 200 || res.status === 201) {
    const body = res.getBody();
    if (body?.data?.id) {
      bru.setEnvVar("urlId", String(body.data.id));
    }
  }
}
