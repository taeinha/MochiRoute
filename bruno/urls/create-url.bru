meta {
  name: Create URL
  type: http
  seq: 1
}

post {
  url: {{apiUrl}}/url
  body: json
  auth: none
}

body:json {
  {
    "originalUrl": "https://example.com/very-long-path"
  }
}

docs {
  Optional auth via auth_token cookie. Anonymous create is allowed.
  Run Login first if you want the URL owned by the logged-in user.
}

script:post-response {
  if (res.status === 200 || res.status === 201) {
    const body = res.getBody();
    const shortUrl = body?.data?.shortUrl;
    if (shortUrl) {
      const shortCode = shortUrl.split("/").pop();
      if (shortCode) {
        bru.setEnvVar("shortCode", shortCode);
      }
    }
  }
}

tests {
  test("should return 201", function() {
    expect(res.getStatus()).to.equal(201);
  });
  test("should return shortUrl", function() {
    expect(res.getBody().data.shortUrl).to.be.a("string");
  });
}
