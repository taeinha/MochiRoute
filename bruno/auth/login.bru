meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{apiUrl}}/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{testEmail}}",
    "password": "{{testPassword}}"
  }
}

script:post-response {
  if (res.status === 200 || res.status === 201) {
    const body = res.getBody();
    if (body?.token) {
      bru.setEnvVar("token", body.token);
    }
  }
}
